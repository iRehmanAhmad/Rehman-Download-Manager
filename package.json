{
  "name": "rdm",
  "version": "0.1.0",
  "description": "Reactive Download Manager - A cross-platform download manager with plugin system, cloud integration, and advanced automation",
  "private": true,
  "main": "./dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,css,md}\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "package:win": "electron-builder --win",
    "package:mac": "electron-builder --mac",
    "package:linux": "electron-builder --linux",
    "package:all": "electron-builder --win --mac --linux"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/react-router-dom": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^42.4.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "electron-context-menu": "^4.1.2",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "ffmpeg-static": "^5.3.0",
    "https-proxy-agent": "^9.1.0",
    "youtube-dl-exec": "^3.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "ffmpeg-static"
    ]
  },
  "build": {
    "appId": "com.rdm.app",
    "productName": "RDM",
    "directories": {
      "output": "release"
    },
    "asarUnpack": [
      "dist/main/browser-bridge/native-host.js"
    ],
    "files": [
      "dist/**/*"
    ],
    "extraFiles": [
      {
        "from": "node_modules/ffmpeg-static/ffmpeg.exe",
        "to": "resources/app.asar.unpacked/node_modules/ffmpeg-static/ffmpeg.exe"
      },
      {
        "from": "node_modules/youtube-dl-exec/bin/yt-dlp.exe",
        "to": "resources/app.asar.unpacked/node_modules/youtube-dl-exec/bin/yt-dlp.exe"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "RDM"
    }
  }
}
