{
  "manifest_version": 2,
  "name": "RDM — Reactive Download Manager",
  "version": "0.1.0",
  "description": "Send downloads directly to RDM. Detect media, intercept links, and download with one click.",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "nativeMessaging",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "RDM",
    "default_icon": "icons/icon.svg"
  },
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "rdm@reactive-download-manager",
      "strict_min_version": "91.0"
    }
  }
}
